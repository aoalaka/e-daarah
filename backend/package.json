{
  "name": "madrasah-admin-backend",
  "version": "1.0.0",
  "description": "Backend API for Madrasah Admin System",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:unit": "node --experimental-vm-modules node_modules/.bin/jest --testPathPatterns=tests/unit",
    "test:api": "node --experimental-vm-modules node_modules/.bin/jest --testPathPatterns=tests/api",
    "migrate": "node migrations/run-migrations.js",
    "migrate:status": "node migrations/run-migrations.js --status"
  },
  "keywords": [
    "madrasah",
    "admin",
    "education"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "csv-parser": "^3.0.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.0.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.0",
    "mysql2": "^3.6.5",
    "resend": "^6.9.1",
    "stripe": "^20.3.0",
    "twilio": "^5.5.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "jest": "^30.0.0-alpha.6",
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2"
  }
}
